local function makeFloatBtn(feat, initPos)
    local btn=Instance.new("TextButton",gui)
    btn.Size=UDim2.new(0,BW,0,BH); btn.Position=initPos
    btn.BackgroundColor3=feat.getState() and BTN_ON or BTN_OFF; btn.BorderSizePixel=0; btn.ZIndex=20
    btn.Text=feat.label; btn.TextColor3=C_WHITE; btn.Font=SPOOK; btn.TextSize=16
