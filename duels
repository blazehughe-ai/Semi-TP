        if not floatEnabled then return end
        pcall(function()
            local c=LocalPlayer.Character; if not c then return end; local rp=c:FindFirstChild("HumanoidRootPart"); if not rp then return end
            local hum=c:FindFirstChildOfClass("Humanoid"); if not hum then return end
            local now=tick()
